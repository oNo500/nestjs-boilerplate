engine-strict=true
enable-pre-post-scripts=true

# Hoist eslint-related packages so oxlint jsPlugins can resolve them at runtime.
# oxlint resolves jsPlugin packages from project root via require(),
# but pnpm strict mode isolates them inside .pnpm/.
public-hoist-pattern[]=eslint
public-hoist-pattern[]=eslint-plugin-*
public-hoist-pattern[]=@darraghor/*
public-hoist-pattern[]=@typescript-eslint/*
