{
  "name": "boilerplate",
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "prepare": "pnpm run setup:env",
    "setup:env": "pnpm --filter api --filter admin-antd --filter admin-shadcn --filter @workspace/database exec cp .env.example .env"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "antd",
        "openapi-fetch",
        "storybook"
      ]
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "bcrypt",
      "better-sqlite3",
      "@swc/core",
      "esbuild"
    ]
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.8"
  }
}
