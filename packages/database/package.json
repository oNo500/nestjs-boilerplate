{
  "name": "@workspace/database",
  "version": "1.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:local": "tsx scripts/local-db.ts"
  },
  "devDependencies": {
    "@infra-x/code-quality": "0.3.2",
    "@infra-x/typescript-config": "latest",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "8.15.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "0.31.6",
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "postgres": "^3.4.8",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "drizzle-orm": "0.44.7",
    "pg": "8.16.3",
    "postgres": "^3.4.8"
  }
}
