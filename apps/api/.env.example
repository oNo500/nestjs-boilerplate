# Environment configuration example
# Copy this file to .env and modify as needed
# Commented-out variables are optional; the default value is shown in parentheses

# Application port (default: 3000)
# PORT=3000

# CORS allowed origins (required in production; comma-separated for multiple)
# ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# Database connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Database connection pool configuration
# DB_POOL_MAX=20                  # Maximum connections (default: 20)
# DB_POOL_MIN=5                   # Minimum connections (default: 5)
# DB_POOL_IDLE_TIMEOUT=30000      # Idle timeout in ms (default: 30000)
# DB_POOL_CONNECTION_TIMEOUT=10000 # Connection timeout in ms (default: 10000)

# JWT configuration
JWT_SECRET=your-secret-key-change-me-in-production-min-32-chars
# JWT_EXPIRES_IN=15m              # Access token expiry (default: 15m)
# JWT_REFRESH_EXPIRES_IN=7d       # Refresh token expiry (default: 7d)

# Redis configuration
REDIS_URL=redis://localhost:6379
# With password: redis://:password@localhost:6379
# REDIS_TTL=3600                  # Default cache TTL in seconds (default: 3600)
