# NestJS API environment variables

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nestjs-boilerplate"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT configuration (required)
JWT_SECRET=your-secret-key-change-me-in-production-min-32-chars
# JWT_EXPIRES_IN=15m              # Access token expiry (default: 15m)
# JWT_REFRESH_EXPIRES_IN=7d       # Refresh token expiry (default: 7d)

# Application port (default: 3000)
# PORT=3000

# CORS allowed origins (required in production; comma-separated for multiple)
# ALLOWED_ORIGINS=https://your-frontend.com

# OAuth (optional; login disabled when not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# OAUTH_CALLBACK_BASE_URL=http://localhost:3000/api/auth/oauth
# FRONTEND_URL=http://localhost:8080
