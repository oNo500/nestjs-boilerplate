{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "description": "NestJS modular layered architecture boilerplate",
  "license": "UNLICENSED",
  "author": "vsa-m-nest",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "check-types": "tsc -b --noEmit",
    "dev": "pnpm start:dev",
    "docker:down": "docker-compose down",
    "docker:up": "docker-compose up -d",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest build && nest start --watch",
    "start:prod": "node dist/main",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config ./vitest.e2e.config.mts",
    "test:ui": "vitest --ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "11.2.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.0.28",
    "@workspace/database": "workspace:*",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dayjs": "^1.11.19",
    "drizzle-orm": "0.44.7",
    "keyv": "^5.6.0",
    "nestjs-cls": "^6.2.0",
    "nestjs-pino": "^4.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "8.16.3",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@golevelup/ts-vitest": "^0.5.2",
    "@infra-x/typescript-config": "latest",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.13",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "8.15.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@workspace/eslint-config": "workspace:*",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.18"
  }
}
